{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "clean-code-reviewer": {
      "path": "./.opencode/SKILL.md"
    }
  },
  "mcp": {
    "figma-desktop": {
        "url": "http://127.0.0.1:3845/mcp",
      "type": "remote",
      "enabled": true
    },
    "chrome-devtools": {
       "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
  }
  }
}

